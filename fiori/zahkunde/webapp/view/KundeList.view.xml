<mvc:View
    controllerName="de.autohaushessen.zahkunde.controller.KundeList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page title="Kundenverwaltung" showNavButton="false">
        <customHeader>
            <Bar>
                <contentLeft><Title text="Kundenverwaltung" level="H4" /></contentLeft>
                <contentMiddle>
                    <SearchField width="100%" placeholder="Name, Ort suchen..." search=".onSearch" />
                </contentMiddle>
                <contentRight>
                    <Button icon="sap-icon://add" text="Neuer Kunde" type="Emphasized" press=".onCreate" />
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <Table
                id="kundeTable"
                items="{ path: '/Kunde', sorter: { path: 'Nachname' } }"
                mode="SingleSelectMaster"
                growing="true"
                growingThreshold="25"
                itemPress=".onItemPress">
                <columns>
                    <Column><Text text="Kundennr." /></Column>
                    <Column><Text text="Anrede" /></Column>
                    <Column><Text text="Name" /></Column>
                    <Column><Text text="Ort" /></Column>
                    <Column><Text text="Telefon" /></Column>
                    <Column><Text text="E-Mail" /></Column>
                    <Column><Text text="Typ" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation">
                        <cells>
                            <Text text="{KundeId}" />
                            <Text text="{Anrede}" />
                            <Text text="{Vorname} {Nachname}" />
                            <Text text="{Plz} {Ort}" />
                            <Text text="{Telefon}" />
                            <Text text="{Email}" />
                            <ObjectStatus
                                text="{= ${Kundentyp} === 'P' ? 'Privat' : 'Gewerbe'}"
                                state="{= ${Kundentyp} === 'P' ? 'Information' : 'Success'}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
