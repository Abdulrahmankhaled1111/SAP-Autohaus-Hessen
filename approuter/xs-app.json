{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/maintenance.html$",
      "target": "maintenance.html",
      "localDir": "resources",
      "authenticationType": "none"
    },
    {
      "source": "^/development-mode.json$",
      "target": "development-mode.json",
      "localDir": "resources",
      "authenticationType": "none"
    },
    {
      "source": "^/assets/icons/(.*)$",
      "target": "assets/icons/$1",
      "localDir": "resources",
      "authenticationType": "none"
    },
    {
      "source": "^/user-api(.*)$",
      "target": "$1",
      "service": "sap-approuter-userapi",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/api/(.*)$",
      "target": "/api/$1",
      "destination": "autohaus-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "localDir": "resources",
      "authenticationType": "xsuaa"
    }
  ],
  "logout": {
    "logoutEndpoint": "/logout",
    "logoutPage": "/maintenance.html?loggedOut=1"
  }
}
